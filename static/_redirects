# Redirect old static site URLs to Hugo URLs

# Old blog page
/blog          /posts/         301
/blog.html     /posts/         301

# Old /category/ paths → /categories/
/category/*   /categories/:splat   301

# Old /tag/ paths → /tags/
/tag/*        /tags/:splat    301

# Old /feed.xml → Hugo RSS
/feed.xml     /index.xml      301

# Sitemap passthrough
/sitemap.xml  /sitemap.xml    200
